{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f package.json ] && grep -q '\"typecheck\"' package.json; then npm run typecheck --silent 2>&1 | tail -n 40; fi; exit 0"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(disown)",
      "Bash(cd *)",
      "Bash(grep *)",
      "Bash(curl *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(git *)",
      "Bash(cat *)",
      "Bash(ls *)"
    ]
  }
}

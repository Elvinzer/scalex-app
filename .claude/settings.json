{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f package.json ] && grep -q '\"typecheck\"' package.json; then npm run typecheck --silent 2>&1 | tail -n 40; fi; exit 0"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(disown)",
      "Bash(cd *)",
      "Bash(grep *)",
      "Bash(curl *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npm audit*)",
      "Bash(sleep *)",
      "Bash(git *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Edit(app/(marketing)/**)",
      "Write(app/(marketing)/**)",
      "Edit(app/(app)/**)",
      "Write(app/(app)/**)",
      "Edit(components/**)",
      "Write(components/**)",
      "Edit(lib/closing/**)",
      "Write(lib/closing/**)",
      "Edit(lib/setting/**)",
      "Write(lib/setting/**)",
      "Edit(lib/inngest/**)",
      "Write(lib/inngest/**)",
      "Edit(app/api/inngest/**)",
      "Write(app/api/inngest/**)",
      "Edit(public/**)",
      "Write(public/**)",
      "Edit(lib/agent/**)",
      "Write(lib/agent/**)",
      "Edit(db/schema.ts)",
      "Write(db/schema.ts)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)"
    ]
  }
}

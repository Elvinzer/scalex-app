# Supabase — project settings > API / Database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres — Supabase project settings > Database > Connection string
# DATABASE_URL: Transaction pooler (Supavisor, port 6543) — used at runtime by the app.
# DIRECT_URL: Session pooler (port 5432, same pooler host as above) — used by
# drizzle-kit for migrations. Not the literal "direct connection" host: on
# projects without the IPv4 add-on, that host is IPv6-only and won't resolve
# from most local/CI networks, so the Session pooler is used instead.
DATABASE_URL=
DIRECT_URL=

# Master key used to encrypt the user's own Anthropic API key and Stripe
# access token before they are stored in the database (AES-256-GCM).
# Never the same value across environments, never committed.
ENCRYPTION_KEY=

# Stripe Connect (OAuth standard accounts) — from the Stripe Dashboard,
# Connect settings. STRIPE_WEBHOOK_SECRET is required to verify webhook
# signatures per the project's non-negotiable rules.
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_CLIENT_SECRET=
STRIPE_WEBHOOK_SECRET=

# Inngest — INNGEST_DEV=1 tells the SDK to talk to the local Inngest Dev
# Server (`npx inngest-cli@latest dev`) instead of Inngest Cloud. Only
# INNGEST_EVENT_KEY / INNGEST_SIGNING_KEY are required in deployed environments.
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

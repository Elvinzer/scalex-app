# Supabase — project settings > API / Database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, full-access key (lib/supabase/admin.ts) — used exclusively by
# deleteAccount (app/(app)/settings/actions.ts) to remove the Supabase Auth
# user itself via auth.admin.deleteUser. Never exposed to the client, never logged.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres — Supabase project settings > Database > Connection string
# DATABASE_URL: Transaction pooler (Supavisor, port 6543) — used at runtime by the app.
# DIRECT_URL: Session pooler (port 5432, same pooler host as above) — used by
# drizzle-kit for migrations. Not the literal "direct connection" host: on
# projects without the IPv4 add-on, that host is IPv6-only and won't resolve
# from most local/CI networks, so the Session pooler is used instead.
DATABASE_URL=
DIRECT_URL=

# Master key used to encrypt the user's own Anthropic API key and Stripe
# access token before they are stored in the database (AES-256-GCM).
# Never the same value across environments, never committed.
ENCRYPTION_KEY=

# Stripe Connect (OAuth standard accounts) — from the Stripe Dashboard,
# Connect settings. STRIPE_WEBHOOK_SECRET is reserved for a Stripe webhook
# receiver that isn't built yet — no route currently calls
# stripe.webhooks.constructEvent with it. Once that webhook exists, per the
# project's non-negotiable rules it MUST verify the signature with this
# secret before acting on any event.
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_CLIENT_SECRET=
STRIPE_WEBHOOK_SECRET=

# Inngest — INNGEST_DEV=1 tells the SDK to talk to the local Inngest Dev
# Server (`npx inngest-cli@latest dev`) instead of Inngest Cloud. Only
# INNGEST_EVENT_KEY / INNGEST_SIGNING_KEY are required in deployed environments.
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Fallback used by lib/agent/client.ts only when a user hasn't configured
# their own BYOK Anthropic key yet. Usage is quota-tracked per user
# (lib/agent/quota.ts) — never the same value as a user's own key, never logged.
ANTHROPIC_SHARED_API_KEY=

# Shared key for the "Améliorer" chat on /diagnostic ONLY (lib/ai-provider.ts,
# app/api/improve-chat/route.ts) — a deliberate, scoped exception to the BYOK
# rule above: this is one shared server-side key for every user, not per-user.
# Groq free tier: https://console.groq.com/keys
GROQ_API_KEY=

# PostHog — product analytics (lib/analytics.ts server-side, lib/analytics-client.ts
# browser-side). NEXT_PUBLIC_POSTHOG_KEY/HOST are exposed to the client on
# purpose (PostHog's project key is not a secret). POSTHOG_PERSONAL_API_KEY is
# a DIFFERENT key (Project Settings > API Keys > Personal API Keys, not the
# project key) used only server-side by lib/posthog-query.ts for the /admin
# HogQL queries — never exposed to the client.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
POSTHOG_KEY=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Resend — Monday weekly-brief email (lib/inngest/functions/weekly-brief-email.ts).
RESEND_API_KEY=

# Absolute origin used to build links inside the Monday email (an Inngest
# scheduled function has no incoming request to read an origin from).
# e.g. https://app.scalex.example — no trailing slash.
APP_URL=

# Same origin, exposed to the client — shown as plain text on the exported
# metric health cards (Dashboard carousel), e.g. "scalex.example".
NEXT_PUBLIC_APP_URL=

# Signs the unsubscribe link token (app/api/unsubscribe/route.ts) so a user
# can't unsubscribe someone else by guessing their user id. Any long random
# string, never the same value as ENCRYPTION_KEY.
UNSUBSCRIBE_TOKEN_SECRET=

# /admin dashboard — comma-separated list of emails allowed in (app/admin/layout.tsx).
ADMIN_EMAILS=
